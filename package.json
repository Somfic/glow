{
  "name": "glow",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync && (svelte-package || echo 'Skipping package build')",
    "package": "svelte-kit sync && svelte-package",
    "prepack": "npm run package && publint",
    "watch": "svelte-kit sync && svelte-package --watch",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./forms": {
      "types": "./dist/forms.d.ts",
      "svelte": "./dist/forms.js"
    },
    "./data": {
      "types": "./dist/data-display.d.ts",
      "svelte": "./dist/data-display.js"
    },
    "./layout": {
      "types": "./dist/layout.d.ts",
      "svelte": "./dist/layout.js"
    },
    "./styles": "./dist/style/glow.scss",
    "./styles/reset": "./dist/style/reset.scss",
    "./styles/global": "./dist/style/global.scss",
    "./styles/theme": "./dist/style/theme.scss"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.64.0",
    "@sveltejs/package": "^2.5.8",
    "@sveltejs/vite-plugin-svelte": "^7",
    "@types/node": "^25",
    "cropperjs": "^1.6.2",
    "hls.js": "^1.6.16",
    "lucide-svelte": "^0.563.0",
    "prettier": "^3.8.4",
    "prettier-plugin-svelte": "^4",
    "publint": "^0.3.21",
    "sass": "^1.100.0",
    "shiki": "^4.2.0",
    "svelte": "^5.56.3",
    "svelte-check": "^4.6.0",
    "typescript": "^6",
    "vite": "^8"
  },
  "keywords": [
    "svelte"
  ],
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10"
  }
}
