{
  "name": "glow",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && npm run package",
    "preview": "vite preview",
    "prepare": "svelte-kit sync && (svelte-package || echo 'Skipping package build')",
    "package": "svelte-kit sync && svelte-package",
    "prepack": "npm run package && publint",
    "watch": "svelte-kit sync && svelte-package --watch",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    },
    "./styles": "./dist/style/glow.scss",
    "./styles/reset": "./dist/style/reset.scss",
    "./styles/global": "./dist/style/global.scss",
    "./styles/theme": "./dist/style/theme.scss"
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "dependencies": {
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/package": "^2.5.7",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/node": "^24",
    "cropperjs": "^1.6.2",
    "hls.js": "^1.6.15",
    "lucide-svelte": "^0.563.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.4.1",
    "publint": "^0.3.17",
    "sass": "^1.97.3",
    "shiki": "^4.0.1",
    "svelte": "^5.48.2",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "keywords": [
    "svelte"
  ],
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10"
  }
}
